# ============================================================
#  NIRAVAN — Tamil Nadu Government Cybersecurity Platform
#  Environment Configuration Template
#  Copy this file to .env and fill in real values before deploying
# ============================================================

# ── Security ──────────────────────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
NIRAVAN_JWT_SECRET=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32

# JWT token expiry in minutes (60 = 1 hour, 480 = 8 hours work day)
NIRAVAN_JWT_EXPIRY_MINUTES=60

# ── Database ──────────────────────────────────────────────
# For production: PostgreSQL (recommended for TN government multi-user deployment)
# NIRAVAN_DB_URL=postgresql://niravan:STRONG_PASSWORD@localhost:5432/niravan_prod
# For development/demo: SQLite (default)
NIRAVAN_DB_URL=sqlite:///niravan_database.db

# ── CORS & Deployment ────────────────────────────────────
# Set to your actual deployed domain (no trailing slash)
# Example: https://niravan.tn.gov.in
NIRAVAN_ALLOWED_ORIGIN=http://localhost

# Application environment
NIRAVAN_ENV=production

# ── Email Alerts (SMTP) ──────────────────────────────────
# Configure for NIC SMTP relay or any SMTP server
NIRAVAN_SMTP_HOST=smtp.nic.in
NIRAVAN_SMTP_PORT=587
NIRAVAN_SMTP_USER=niravan@tn.gov.in
NIRAVAN_SMTP_PASS=CHANGE_ME
NIRAVAN_ALERT_EMAIL=soc-team@tn.gov.in

# ── Department Config ────────────────────────────────────
NIRAVAN_ORG_NAME=Tamil Nadu Government
NIRAVAN_ORG_DEPT=Information Technology Department
NIRAVAN_DISTRICT=Chennai

# ── CERT-In Reporting ────────────────────────────────────
# CERT-In incident reporting webhook (if available)
NIRAVAN_CERTIN_WEBHOOK=https://www.cert-in.org.in/report

# ── Rate Limiting ────────────────────────────────────────
NIRAVAN_LOGIN_RATE_LIMIT=5/minute
NIRAVAN_API_RATE_LIMIT=100/minute
